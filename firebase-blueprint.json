{
  "entities": {
    "SiteConfig": {
      "title": "Site Configuration",
      "description": "Global settings and content for the website.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "experience": { "type": "string" },
        "availability": { "type": "string" },
        "profileImage": { "type": "string" },
        "logoUrl": { "type": "string" },
        "socialLinks": {
          "type": "object",
          "properties": {
            "behance": { "type": "string" },
            "whatsapp": { "type": "string" },
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "linkedin": { "type": "string" }
          }
        },
        "theme": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "accentColor": { "type": "string" },
            "darkMode": { "type": "boolean" },
            "sectionColors": {
              "type": "object",
              "properties": {
                "hero": { "type": "string" },
                "skills": { "type": "string" },
                "projects": { "type": "string" },
                "testimonials": { "type": "string" },
                "cta": { "type": "string" },
                "about": { "type": "string" },
                "services": { "type": "string" },
                "contact": { "type": "string" },
                "text": { "type": "string" }
              }
            }
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "icon": { "type": "string" }
            }
          }
        },
        "testimonials": {
          "type": "array",
          "items": {
            "$ref": "Testimonial"
          }
        },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "year": { "type": "string" },
              "title": { "type": "string" },
              "company": { "type": "string" },
              "desc": { "type": "string" }
            }
          }
        },
        "pageContent": {
          "type": "object",
          "properties": {
            "home": {
              "type": "object",
              "properties": {
                "heroTitle": { "type": "string" },
                "heroSubtitle": { "type": "string" },
                "ctaTitle": { "type": "string" },
                "ctaSubtitle": { "type": "string" }
              }
            },
            "about": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "subtitle": { "type": "string" }
              }
            },
            "services": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "subtitle": { "type": "string" }
              }
            },
            "contact": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "subtitle": { "type": "string" }
              }
            }
          }
        },
        "contactInfo": {
          "type": "object",
          "properties": {
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" },
            "whatsapp": { "type": "string" }
          }
        },
        "homeBlocks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string", "enum": ["hero", "skills", "projects", "testimonials", "cta", "text"] },
              "enabled": { "type": "boolean" },
              "data": { "type": "object" }
            }
          }
        }
      }
    },
    "Project": {
      "title": "Portfolio Project",
      "description": "A project showcased in the portfolio.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "link": { "type": "string" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "imageUrl"]
    },
    "Service": {
      "title": "Service Offering",
      "description": "A service provided by the freelancer.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "icon": { "type": "string" },
        "order": { "type": "integer" }
      },
      "required": ["title"]
    },
    "Testimonial": {
      "title": "Client Testimonial",
      "description": "Feedback from a client.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "content": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "content"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "A message sent via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["name", "email", "message"]
    },
    "Admin": {
      "title": "Admin User",
      "description": "Users with administrative access.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      }
    }
  },
  "firestore": {
    "config/site": {
      "schema": "SiteConfig",
      "description": "Global site configuration document."
    },
    "projects": {
      "schema": "Project",
      "description": "Collection of portfolio projects."
    },
    "services": {
      "schema": "Service",
      "description": "Collection of services offered."
    },
    "testimonials": {
      "schema": "Testimonial",
      "description": "Collection of client testimonials."
    },
    "messages": {
      "schema": "Message",
      "description": "Collection of contact form messages."
    },
    "admins": {
      "schema": "Admin",
      "description": "Collection of admin users."
    }
  }
}
